<?xml version="1.0" encoding="UTF-8"?>

<plugin id="es.seogirona.cordova.apns.push"
        version="1.0.0"
        xmlns="http://apache.org/cordova/ns/plugins/1.0"
        xmlns:android="http://schemas.android.com/apk/res/android">

    <name>es.seogirona.cordova.apns.push</name>

    <description>
        Cordova plugin for iOS APNs push notifications without Firebase.
    </description>

    <license>MIT</license>

    <keywords>
        cordova, ios, apns, push, notification
    </keywords>

    <engines>
        <engine name="cordova" version=">=8.0.0"/>
        <engine name="cordova-ios" version=">=5.0.0"/>
    </engines>

    <!-- Variable for APNs environment: development | production -->
    <preference name="APNS_ENV" default="production"/>

    <!-- JS interface -->
    <js-module src="www/PushNotification.js" name="PushNotification">
        <clobbers target="PushNotification"/>
    </js-module>

    <!-- iOS platform -->
    <platform name="ios">

        <!-- Register plugin in Cordova -->
        <config-file target="config.xml" parent="/*">
            <feature name="APNSPush">
                <param name="ios-package" value="APNSPush"/>
            </feature>
        </config-file>

        <!-- Native iOS files -->
        <header-file src="src/ios/APNSPush.h"/>
        <source-file src="src/ios/APNSPush.m"/>

        <header-file src="src/ios/APNSPush+Swizzle.h"/>
        <source-file src="src/ios/APNSPush+Swizzle.m"/>

        <!-- Notification permission text -->
        <config-file target="*-Info.plist" parent="NSUserNotificationUsageDescription">
            <string>This app uses push notifications to keep you informed.</string>
        </config-file>

        <!-- Enable background remote notifications -->
        <config-file target="*-Info.plist" parent="UIBackgroundModes">
            <array>
                <string>remote-notification</string>
            </array>
        </config-file>

        <!-- Hooks: create entitlements + patch Xcode project -->
        <hook type="after_platform_add" src="scripts/ios-entitlements-force.js"/>
        <hook type="after_prepare" src="scripts/ios-entitlements-force.js"/>

    </platform>

</plugin>
